# Copy to .env.local and fill in real values (.env.local is gitignored).
# All NEXT_PUBLIC_* vars are inlined into the browser bundle — they must be
# browser-safe. The publishable key is safe to expose; the service_role/secret
# key must NEVER be put here.

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...   # publishable / anon — browser-safe, NOT secret
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
