# Скопируй этот файл в secrets.sh (без .example) и впиши свои ключи.
# Потом закрой доступ:  chmod 600 secrets.sh
# Этот файл НИКОМУ не показывай и в чат не вставляй.
export ANTHROPIC_API_KEY="sk-ant-твой-новый-ключ"

# --- Supabase ---
# SUPABASE_URL и SUPABASE_SECRET_KEY (service_role) — серверные, секретные.
export SUPABASE_URL="https://<project-ref>.supabase.co"
export SUPABASE_SECRET_KEY="sb_secret_..."        # service_role / secret — НЕ публиковать

# SUPABASE_ANON_KEY — ПУБЛИЧНЫЙ anon/publishable ключ (не секрет). Нужен для
# user-scoped пути: бэкенд ходит под ним + JWT пользователя, чтобы сработал RLS.
export SUPABASE_ANON_KEY="sb_publishable_..."     # anon/publishable — публичный, не секретный
